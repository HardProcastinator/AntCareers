    $hr=$k?"employer_manageJobs.php?status={$k}":'employer_manageJobs.php';
  ?>
  <a class="stat-pill <?=$act?'active':''?>" href="<?=htmlspecialchars($hr)?>">
    <i class="fas <?=$d['i']?> sp-icon" style="color:<?=$d['c']?>"></i>
    <span class="sp-label"><?=$d['l']?></span>
