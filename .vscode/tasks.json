{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sync to htdocs",
      "type": "process",
      "command": "powershell.exe",
      "args": ["-ExecutionPolicy", "Bypass", "-NonInteractive", "-File", "${workspaceFolder}\\.vscode\\sync-htdocs.ps1"],
